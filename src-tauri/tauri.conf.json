{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MarkForge",
  "version": "0.1.0",
  "identifier": "me.aiplanet.markforge",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "MarkForge · 批量水印",
        "width": 1280,
        "height": 860,
        "minWidth": 1020,
        "minHeight": 720,
        "dragDropEnabled": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
